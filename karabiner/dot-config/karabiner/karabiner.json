{
    "global": { "show_in_menu_bar": false },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Hyper + G to open Browser",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "g",
                                    "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "~/.config/yabai/focus_browser.sh" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper + Space to open Spotlight",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "spacebar",
                                    "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
                                },
                                "to": [
                                    {
                                        "key_code": "spacebar",
                                        "modifiers": ["left_command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper + E to open Finder",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "e",
                                    "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "open -a 'Finder'" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper + T to open Terminal",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "t",
                                    "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
                                },
                                "to": [{ "shell_command": "~/.config/yabai/focus_terminal.sh" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper + C to Close Window",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "c",
                                    "modifiers": { "mandatory": ["left_command", "left_control", "left_option", "left_shift"] }
                                },
                                "to": [
                                    {
                                        "key_code": "q",
                                        "modifiers": ["left_command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Caps Lock to Escape and Hyper",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_command", "left_control", "left_option"]
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "simple_modifications": [
                {
                    "from": { "key_code": "right_command" },
                    "to": [{ "key_code": "right_option" }]
                }
            ],
            "virtual_hid_keyboard": { "keyboard_type_v2": "iso" }
        }
    ]
}